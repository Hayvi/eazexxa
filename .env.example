# Server
PORT=3001
NODE_ENV=production
TRUST_PROXY=1

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Database
DB_HOST=/var/run/postgresql
DB_PORT=5432
DB_NAME=betpro
DB_USER=postgres
DB_PASSWORD=
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONN_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=15000
DB_STATEMENT_TIMEOUT_MS=15000
DB_IDLE_IN_TX_TIMEOUT_MS=10000
DB_POOL_MAX_USES=7500
DB_APP_NAME=betpro-server

# Redis
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true
REDIS_WS_CHANNEL=betpro:ws:broadcast

# Swarm (DOB)
SWARM_WS_URL=ws://localhost:9999
SWARM_SITE_ID=4
SWARM_LANG=eng

# Settlement
SETTLEMENT_LEADER_LOCK_KEY=betpro:settlement:leader
SETTLEMENT_LEADER_TTL_SEC=900
SETTLEMENT_GAME_LOCK_TTL_SEC=120
SETTLEMENT_IDEMPOTENCY_TTL_SEC=600
SETTLEMENT_STALE_FINAL_OUTCOME_TTL_SEC=900
SETTLEMENT_NOT_FINAL_RESOLVER_TTL_SEC=172800
SETTLEMENT_REDIS_FAIL_OPEN=true
SETTLEMENT_POLL_INTERVAL_MS=60000

# Betting
BET_PLACEMENT_SLOW_THRESHOLD_MS=1000

# Workers
WS_NODE_ID=
